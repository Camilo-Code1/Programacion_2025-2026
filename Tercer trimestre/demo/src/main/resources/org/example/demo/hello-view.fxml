<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="382.0" prefWidth="468.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <Pane prefHeight="327.0" prefWidth="428.0">
      <children>
          <Button fx:id="onPasarPantalla" layoutX="116.0" layoutY="214.0" onAction="#onPasarPantalla" text="Siguiente pantalla">            <font>
               <Font size="18.0" />
            </font>
         </Button>
         <Button layoutX="140.0" layoutY="59.0" onAction="#onNightHelloClick" text="Buenos dias">
            <font>
               <Font size="18.0" />
            </font>
         </Button>
      </children>
   </Pane>

    <Label fx:id="welcomeText" />
</VBox>
