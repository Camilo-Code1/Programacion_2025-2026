<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="382.0" prefWidth="468.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <Pane prefHeight="327.0" prefWidth="428.0">
      <children>
          <Button layoutX="124.0" layoutY="213.0" onAction="#onBackButtonClick" text="Volver al comienzo ">
            <font>
               <Font size="18.0" />
            </font>
         </Button>
         <Button layoutX="155.0" layoutY="60.0" onAction="#onSegundoImpaClick" prefHeight="90.0" prefWidth="110.0" text="Secundo impacto" textAlignment="CENTER" wrapText="true">
            <font>
               <Font size="18.0" />
            </font>
         </Button>
      </children>
   </Pane>

    <Label fx:id="welcomeText" />
</VBox>
